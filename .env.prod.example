# Copy to .env.prod on the VPS (in /opt/allocation-system... see deploy/deploy.sh)
# and fill in real values. NEVER commit the real .env.prod file.
#
# Shared between both tasks' backends via docker-compose.prod.yml's per-service
# `environment:` mapping (see that file's header comment for why namespacing
# matters here).

# --- Shared ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Task 1: Course Allocation ---
TASK1_POSTGRES_USER=allocation_user
TASK1_POSTGRES_PASSWORD=change-me-strong-password
TASK1_POSTGRES_DB=allocation_db
TASK1_SECRET_KEY=change-me-long-random-string
TASK1_CORS_ORIGIN=https://allocation.harveedesigns.com

# --- Task 2: AI SQL Assistant ---
TASK2_POSTGRES_USER=sqlassistant_user
TASK2_POSTGRES_PASSWORD=change-me-strong-password
TASK2_POSTGRES_DB=sqlassistant_db
TASK2_READONLY_DB_USER=sqlassistant_readonly
TASK2_READONLY_DB_PASSWORD=change-me-strong-password-different-from-above
TASK2_CORS_ORIGIN=https://sql-assistant.harveedesigns.com
