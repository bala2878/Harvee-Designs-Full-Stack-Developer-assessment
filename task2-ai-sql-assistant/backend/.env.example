# Copy to .env for local development. NEVER commit the real .env file.

ENVIRONMENT=development
DEBUG=true

BACKEND_CORS_ORIGINS=http://localhost:4201

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sqlassistant_user
POSTGRES_PASSWORD=sqlassistant_pass
POSTGRES_DB=sqlassistant_db

# Read-only role used ONLY to execute AI-generated SQL — see docs/ARCHITECTURE.md.
# Provisioned automatically by alembic/versions/0001_initial_schema.py for local
# dev; production should re-run deploy/provision-readonly-role.sql with a real
# password instead of this placeholder.
READONLY_DB_USER=sqlassistant_readonly
READONLY_DB_PASSWORD=sqlassistant_readonly_pass

DATASET_SCHEMA=datasets
MAX_RESULT_ROWS=500
QUERY_TIMEOUT_SECONDS=10
MAX_UPLOAD_ROWS=200000
MAX_UPLOAD_SIZE_MB=25

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-6
